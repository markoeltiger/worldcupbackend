# ============================================================
# GoalIQ Live — .gitignore
# ============================================================

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local
*.pem
firebase-adminsdk*.json

# --- Logs ---
logs/
*.log

# --- Build artifacts ---
dist/
build/
.cache/

# --- Test coverage ---
coverage/
.nyc_output/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Playwright browser binaries (heavy, not needed in CI/CD) ---
**/playwright/.local-browsers/
